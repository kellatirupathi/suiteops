# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Supabase (PostgreSQL) — server-side service role key (NEVER expose to browser)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# MongoDB — only needed to run the one-time migration (npm run migrate)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/suitesops

# Auth
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=8h

# Seed default accounts
SEED_MANAGER_EMAIL=manager@rksuites.com
SEED_MANAGER_PASSWORD=Manager@123
SEED_FRONTDESK_EMAIL=frontdesk@rksuites.com
SEED_FRONTDESK_PASSWORD=Frontdesk@123
